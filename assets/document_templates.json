        {
          "type": "paragraph",
          "text": ""
        },
        {
          "type": "paragraph",
          "text": "特此证明。",
          "indent": 2
        },
        {
          "type": "paragraph",
          "text": ""
        },
        {
          "type": "paragraph",
          "text": ""
        },
        {
          "type": "paragraph",
          "text": "{{company_name}}",
          "align": "right"
        },
        {
          "type": "paragraph",
          "text": "{{current_date}}",
          "align": "right"
        },
        {
          "type": "paragraph",
          "text": "（盖章）",
          "align": "right"
        }
      ]
    }
