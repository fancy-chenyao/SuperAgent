{
  "resources": [
    {
      "type": "agent",
      "name": "RemoteWeatherAgent",
      "version": "1.0.0",
      "endpoint": "http://127.0.0.1:8010/agent",
      "protocol": "http",
      "server_id": "remote-demo",
      "health_url": "http://127.0.0.1:8010/health",
      "metadata": {
        "description": "Remote weather agent for querying weather information of specific locations. Use this agent when you need to check weather conditions for cities or regions. This agent autonomously extracts location information from the conversation context.",
        "llm_type": "basic",
        "prompt": "You are a weather query agent. Use the remote_weather_tool to get weather information for the specified location.",
        "selected_tools": [
          {
            "name": "remote_weather_tool",
            "description": "Query weather information for a specific location",
            "parameters": {
              "type": "object",
              "properties": {
                "location": {
                  "type": "string",
                  "description": "The name of the city or region to query weather for, e.g., '雄安新区', '北京', '上海'"
                }
              },
              "required": ["location"]
            }
          }
        ]
      }
    },
    {
      "type": "agent",
      "name": "RemotePersonInfoAgent",
      "version": "1.0.0",
      "endpoint": "http://127.0.0.1:8010/agent",
      "protocol": "http",
      "server_id": "remote-demo",
      "health_url": "http://127.0.0.1:8010/health",
      "metadata": {
        "description": "Remote person info agent for querying personnel data. This agent autonomously extracts query information from the conversation context.",
        "llm_type": "basic",
        "prompt": "remote person info agent",
        "selected_tools": [
          {
            "name": "remote_person_info_tool",
            "description": "Query personnel information from internal database",
            "parameters": {
              "type": "object",
              "properties": {
                "keyword": {
                  "type": "string",
                  "description": "Search keyword for person name or job title"
                },
                "job_keywords": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "Job title keywords, e.g., ['行长秘书', '经理']"
                },
                "org_keywords": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "Organization keywords, e.g., ['支行', '分行']"
                },
                "gender": {
                  "type": "string",
                  "enum": ["男", "女"],
                  "description": "Gender filter"
                },
                "limit": {
                  "type": "integer",
                  "description": "Maximum number of results",
                  "default": 5
                }
              }
            }
          }
        ]
      }
    },
