    {
      "type": "agent",
      "name": "RemoteBusinessRiskAgent",
      "version": "1.0.0",
      "endpoint": "http://127.0.0.1:8010/agent",
      "protocol": "http",
      "server_id": "remote-demo",
      "health_url": "http://127.0.0.1:8010/health",
      "metadata": {
        "description": "Remote agent to query credit risk DB for business & risk metrics. This agent autonomously extracts company information from previous steps in the conversation.",
        "llm_type": "basic",
        "prompt": "remote business risk agent",
        "selected_tools": [
          {
            "name": "remote_credit_risk_db_tool",
            "description": "Query credit risk metrics for companies",
            "parameters": {
              "type": "object",
              "properties": {
                "company_ids": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "List of company IDs to query risk metrics for. Extract from previous unicorn query results."
                },
                "companies": {
                  "type": "array",
                  "description": "Alternative: array of company objects with id/name fields"
                }
              },
              "required": ["company_ids"]
            }
          }
        ]
      }
    },
    {
      "type": "agent",
      "name": "RemoteReportAgent",
      "version": "1.0.0",
      "endpoint": "http://127.0.0.1:8010/agent",
      "protocol": "http",
      "server_id": "remote-demo",
      "health_url": "http://127.0.0.1:8010/health",
      "metadata": {
        "description": "Remote agent to build markdown reports from structured inputs. This agent autonomously extracts analysis data from previous steps in the conversation.",
        "llm_type": "basic",
        "prompt": "remote report agent",
        "selected_tools": [
          {
            "name": "remote_report_builder_tool",
            "description": "Build markdown reports from structured data or raw analysis results",
            "parameters": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "array",
                  "description": "Raw data array from previous analysis steps (e.g., unicorn records, risk metrics). The tool will use LLM to generate a comprehensive report from this data."
                },
                "sections": {
                  "type": "array",
                  "description": "Pre-structured report sections with heading and content",
                  "items": {
                    "type": "object",
                    "properties": {
                      "heading": {"type": "string"},
                      "content": {"type": "string"}
                    }
                  }
                },
                "title": {
                  "type": "string",
                  "description": "Report title",
                  "default": "分析报告"
                },
                "instruction": {
                  "type": "string",
                  "description": "Instructions for report generation",
                  "default": "生成清晰、专业的Markdown分析报告"
                }
              },
              "required": ["data"]
            }
          }
        ]
      }
    },
