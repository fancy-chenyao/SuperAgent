{
  "resources": [
    {
      "type": "agent",
      "name": "RemoteWeatherAgent",
      "version": "1.0.0",
      "endpoint": "http://127.0.0.1:8010/agent",
      "protocol": "http",
      "server_id": "remote-demo",
      "health_url": "http://127.0.0.1:8010/health",
      "metadata": {
        "description": "Remote weather agent for querying weather information of specific locations. Use this agent when you need to check weather conditions for cities or regions. This agent autonomously extracts location information from the conversation context.",
        "llm_type": "basic",
        "prompt": "You are a weather query agent. Use the remote_weather_tool to get weather information for the specified location.",
        "selected_tools": [
          {
            "name": "remote_weather_tool",
            "description": "Query weather information for a specific location",
            "parameters": {
              "type": "object",
              "properties": {
                "location": {
                  "type": "string",
                  "description": "The name of the city or region to query weather for, e.g., '雄安新区', '北京', '上海'"
                }
              },
              "required": ["location"]
            }
          }
        ]
      }
    },
    {
      "type": "agent",
      "name": "RemoteHRAssistantAgent",
      "version": "1.0.0",
      "endpoint": "http://127.0.0.1:8010/agent",
      "protocol": "http",
      "server_id": "remote-demo",
      "health_url": "http://127.0.0.1:8010/health",
      "metadata": {
        "description": "Remote HR assistant agent for querying personnel and salary data. Can query employee basic information, salary details, and other HR-related data. This agent autonomously extracts query information from the conversation context.",
        "llm_type": "basic",
        "prompt": "You are an HR assistant agent. You can query employee information and salary data from the internal HR system.",
        "selected_tools": [
          {
            "name": "remote_person_info_tool",
            "description": "Query personnel information from internal database",
            "parameters": {
              "type": "object",
              "properties": {
                "keyword": {
                  "type": "string",
                  "description": "Search keyword for person name or job title"
                },
                "job_keywords": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "Job title keywords (will match if ANY keyword is found), e.g., ['行长', '秘书', '经理']. For '行长秘书', split into ['行长', '秘书']"
                },
                "org_keywords": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "Organization keywords (will match if ANY keyword is found), e.g., ['支行', '分行', '二级']. For '二级分支行', split into ['二级', '分行'] or ['二级', '支行']"
                },
                "gender": {
                  "type": "string",
                  "enum": ["男", "女"],
                  "description": "Gender filter"
                },
                "birth_year_range": {
                  "type": "array",
                  "items": {"type": "integer"},
                  "minItems": 2,
                  "maxItems": 2,
                  "description": "Birth year range [start_year, end_year]. Examples: '80后' -> [1980, 1989], '90后' -> [1990, 1999], '70后' -> [1970, 1979]"
                },
                "age_min": {
                  "type": "integer",
                  "description": "Minimum age"
                },
                "age_max": {
                  "type": "integer",
                  "description": "Maximum age"
                },
                "limit": {
                  "type": "integer",
                  "description": "Maximum number of results",
                  "default": 5
                }
              }
            }
          },
          {
            "name": "remote_salary_info_tool",
            "description": "Query employee salary and income information from HR system",
            "parameters": {
              "type": "object",
              "properties": {
                "employee_id": {
                  "type": "string",
                  "description": "Employee ID (e.g., '7位工号' or '15位工号')"
                },
                "employee_name": {
                  "type": "string",
                  "description": "Employee name"
                },
                "include_breakdown": {
                  "type": "boolean",
                  "description": "Whether to include detailed salary breakdown (base salary, bonus, allowance, etc.)",
                  "default": true
                }
              }
            }
          }
        ]
      }
    },
