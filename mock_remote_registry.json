                "data": {
                  "type": "object",
                  "description": "Data to fill into the template. Should include employee info, salary info, etc."
                },
                "output_filename": {
                  "type": "string",
                  "description": "Output filename (without extension, .docx will be added automatically)"
                }
              },
              "required": ["template_name", "data"]
            }
          }
